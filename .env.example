# MySQL (used by docker-compose)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=vault_pad

# Application
# For Docker: use "db" as host. For local dev without Docker: replace "db" with "127.0.0.1"
DATABASE_DSN=root:root@tcp(db:3306)/vault_pad?parseTime=true
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
LISTEN_ADDR=:8080
SEED_ADMIN_EMAIL=admin@local.local
